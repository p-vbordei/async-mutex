{
  "name": "@p-vbordei/async-mutex",
  "version": "0.1.0",
  "description": "Tiny async mutex, RWLock (writer-preference), and counting semaphore. Zero dependencies.",
  "keywords": [
    "mutex",
    "lock",
    "semaphore",
    "rwlock",
    "async",
    "concurrency"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "author": {
    "name": "Vlad Bordei",
    "email": "bordeivlad@gmail.com",
    "url": "https://github.com/p-vbordei"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/p-vbordei/async-mutex.git"
  },
  "bugs": {
    "url": "https://github.com/p-vbordei/async-mutex/issues"
  },
  "homepage": "https://github.com/p-vbordei/async-mutex#readme",
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
